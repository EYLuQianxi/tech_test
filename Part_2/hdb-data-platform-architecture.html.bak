<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>HDB Data Platform — Data Ingestion &amp; Exploitation Architecture</title>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'JetBrains Mono', monospace;
      background: #020617;
      min-height: 100vh;
      padding: 2rem;
      color: white;
    }
    .container { max-width: 1200px; margin: 0 auto; }
    .header { margin-bottom: 2rem; }
    .header-row {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 0.5rem;
    }
    .pulse-dot {
      width: 12px; height: 12px;
      background: #22d3ee;
      border-radius: 50%;
      animation: pulse 2s infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.5; }
    }
    h1 {
      font-size: 1.5rem;
      font-weight: 700;
      letter-spacing: -0.025em;
    }
    .subtitle {
      color: #94a3b8;
      font-size: 0.875rem;
      margin-left: 1.75rem;
    }
    .diagram-container {
      background: rgba(15, 23, 42, 0.5);
      border-radius: 1rem;
      border: 1px solid #1e293b;
      padding: 1.5rem;
      overflow-x: auto;
    }
    svg {
      width: 100%;
      min-width: 900px;
      display: block;
    }
    .footer {
      text-align: center;
      margin-top: 2rem;
      color: #475569;
      font-size: 0.75rem;
    }
  </style>
</head>
<body>
  <div class="container">
    <!-- Header -->
    <div class="header">
      <div class="header-row">
        <div class="pulse-dot"></div>
        <h1>HDB Data Platform Architecture</h1>
      </div>
      <p class="subtitle">Data Ingestion from data.gov.sg &amp; Data Exploitation via Tableau on AWS</p>
    </div>

    <!-- Main Diagram -->
    <div class="diagram-container">
      <svg viewBox="0 0 1150 840">
        <defs>
          <marker id="arrowhead" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
            <polygon points="0 0, 10 3.5, 0 7" fill="#64748b" />
          </marker>
          <marker id="arrowhead-rose" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
            <polygon points="0 0, 10 3.5, 0 7" fill="#fb7185" />
          </marker>
          <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
            <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#1e293b" stroke-width="0.5"/>
          </pattern>
        </defs>

        <!-- Background Grid -->
        <rect width="1150" height="840" fill="url(#grid)" />

        <!-- ========================================= -->
        <!-- ARROWS (drawn early, behind components)     -->
        <!-- ========================================= -->

        <!-- 1. EventBridge -> Step Functions -->
        <line x1="380" y1="270" x2="380" y2="295" stroke="#34d399" stroke-width="1.5" marker-end="url(#arrowhead)" />
        <text x="395" y="282" fill="#94a3b8" font-size="8">trigger</text>

        <!-- 2. Step Functions -> Fargate -->
        <line x1="380" y1="345" x2="380" y2="370" stroke="#34d399" stroke-width="1.5" marker-end="url(#arrowhead)" />
        <text x="395" y="358" fill="#94a3b8" font-size="8">orchestrate</text>

        <!-- 3. data.gov.sg -> NAT Gateway (data acquisition) -->
        <path d="M 195 290 L 220 290 L 220 127 L 300 127" fill="none" stroke="#fb7185" stroke-width="1.5" stroke-dasharray="5,4" />
        <polygon points="300,123 310,127 300,131" fill="#fb7185" />
        <text x="180" y="270" fill="#fb7185" font-size="8">HTTPS download</text>

        <!-- 4. NAT Gateway -> Fargate -->
        <path d="M 300 127 L 250 127 L 250 370 L 300 370" fill="none" stroke="#fb7185" stroke-width="1.5" stroke-dasharray="5,4" />
        <polygon points="300,366 310,370 300,374" fill="#fb7185" />

        <!-- 5. Fargate -> S3 (stream raw data) -->
        <path d="M 460 397 L 500 397 L 500 490 L 540 490" fill="none" stroke="#a78bfa" stroke-width="1.5" marker-end="url(#arrowhead)" />
        <text x="475" y="390" fill="#94a3b8" font-size="8">stream to S3</text>

        <!-- 6. S3 -> Glue Data Catalog (crawler) -->
        <line x1="615" y1="540" x2="615" y2="570" stroke="#a78bfa" stroke-width="1.5" stroke-dasharray="4,3" marker-end="url(#arrowhead)" />
        <text x="625" y="555" fill="#94a3b8" font-size="8">crawl</text>

        <!-- 7. Athena -> S3 (query execution reads data) -->
        <path d="M 900 297 L 850 297 L 850 180 L 635 180 L 635 230" fill="none" stroke="#a78bfa" stroke-width="1.5" stroke-dasharray="4,3" marker-end="url(#arrowhead)" />
        <text x="720" y="175" fill="#94a3b8" font-size="8">query execution</text>

        <!-- 8. Tableau -> Athena (via Athena Driver) -->
        <line x1="970" y1="370" x2="970" y2="325" stroke="#22d3ee" stroke-width="1.5" marker-end="url(#arrowhead)" />
        <text x="985" y="350" fill="#94a3b8" font-size="8">Athena Driver</text>

        <!-- 9. Athena -> VPC Endpoint (Athena) private link indicator -->
        <path d="M 900 297 L 750 297 L 750 315 L 690 315" fill="none" stroke="#fb7185" stroke-width="1.5" stroke-dasharray="4,3" marker-end="url(#arrowhead-rose)" />
        <text x="800" y="290" fill="#fb7185" font-size="7">PrivateLink</text>

        <!-- ========================================= -->
        <!-- BOUNDARIES                                  -->
        <!-- ========================================= -->

        <!-- VPC Boundary -->
        <rect x="230" y="50" width="880" height="710" rx="12" fill="rgba(251, 191, 36, 0.03)" stroke="#fbbf24" stroke-width="1.5" stroke-dasharray="10,6" />
        <text x="245" y="68" fill="#fbbf24" font-size="11" font-weight="600">AWS VPC — HDB Data Platform</text>

        <!-- Public Subnet label -->
        <text x="245" y="90" fill="#94a3b8" font-size="9">Public Subnet</text>

        <!-- Private Subnet — Ingestion label -->
        <text x="245" y="205" fill="#94a3b8" font-size="9">Private Subnet — Ingestion</text>

        <!-- Security Group: Ingestion -->
        <rect x="260" y="225" width="240" height="295" rx="8" fill="transparent" stroke="#fb7185" stroke-width="1" stroke-dasharray="4,4" />
        <text x="270" y="240" fill="#fb7185" font-size="8">sg-ingestion (outbound :443)</text>

        <!-- Private Subnet — VPC Endpoints label -->
        <text x="535" y="205" fill="#94a3b8" font-size="9">Private Subnet — VPC Endpoints</text>

        <!-- Private Subnet — Analytics label -->
        <text x="870" y="205" fill="#94a3b8" font-size="9">Private Subnet — Analytics</text>

        <!-- Security Group: Analytics -->
        <rect x="870" y="225" width="210" height="160" rx="8" fill="transparent" stroke="#fb7185" stroke-width="1" stroke-dasharray="4,4" />
        <text x="880" y="240" fill="#fb7185" font-size="8">sg-analytics (:443)</text>

        <!-- ========================================= -->
        <!-- COMPONENTS                                  -->
        <!-- ========================================= -->

        <!-- data.gov.sg (External) -->
        <rect x="50" y="260" width="140" height="60" rx="6" fill="#0f172a" stroke="#94a3b8" stroke-width="1.5" />
        <rect x="50" y="260" width="140" height="60" rx="6" fill="rgba(30, 41, 59, 0.5)" stroke="#94a3b8" stroke-width="1.5" />
        <text x="120" y="285" fill="white" font-size="11" font-weight="600" text-anchor="middle">data.gov.sg</text>
        <text x="120" y="302" fill="#94a3b8" font-size="9" text-anchor="middle">Public API</text>

        <!-- NAT Gateway (AWS/Cloud) -->
        <rect x="300" y="100" width="150" height="55" rx="6" fill="#0f172a" stroke="#fbbf24" stroke-width="1.5" />
        <rect x="300" y="100" width="150" height="55" rx="6" fill="rgba(120, 53, 15, 0.3)" stroke="#fbbf24" stroke-width="1.5" />
        <text x="375" y="122" fill="white" font-size="11" font-weight="600" text-anchor="middle">NAT Gateway</text>
        <text x="375" y="138" fill="#94a3b8" font-size="9" text-anchor="middle">Outbound Internet</text>

        <!-- EventBridge (Backend/Compute) -->
        <rect x="300" y="220" width="160" height="50" rx="6" fill="#0f172a" stroke="#34d399" stroke-width="1.5" />
        <rect x="300" y="220" width="160" height="50" rx="6" fill="rgba(6, 78, 59, 0.4)" stroke="#34d399" stroke-width="1.5" />
        <text x="380" y="240" fill="white" font-size="11" font-weight="600" text-anchor="middle">EventBridge</text>
        <text x="380" y="256" fill="#94a3b8" font-size="9" text-anchor="middle">Scheduler</text>

        <!-- Step Functions (Backend/Compute) -->
        <rect x="300" y="295" width="160" height="50" rx="6" fill="#0f172a" stroke="#34d399" stroke-width="1.5" />
        <rect x="300" y="295" width="160" height="50" rx="6" fill="rgba(6, 78, 59, 0.4)" stroke="#34d399" stroke-width="1.5" />
        <text x="380" y="315" fill="white" font-size="11" font-weight="600" text-anchor="middle">Step Functions</text>
        <text x="380" y="331" fill="#94a3b8" font-size="9" text-anchor="middle">Orchestration</text>

        <!-- ECS Fargate (Backend/Compute) -->
        <rect x="300" y="370" width="160" height="55" rx="6" fill="#0f172a" stroke="#34d399" stroke-width="1.5" />
        <rect x="300" y="370" width="160" height="55" rx="6" fill="rgba(6, 78, 59, 0.4)" stroke="#34d399" stroke-width="1.5" />
        <text x="380" y="390" fill="white" font-size="11" font-weight="600" text-anchor="middle">ECS Fargate</text>
        <text x="380" y="408" fill="#94a3b8" font-size="9" text-anchor="middle">Large File Download</text>
        <text x="380" y="418" fill="#fbbf24" font-size="7" text-anchor="middle">&gt;100 MB streaming</text>

        <!-- Lambda (Backend/Compute) -->
        <rect x="300" y="450" width="160" height="50" rx="6" fill="#0f172a" stroke="#34d399" stroke-width="1.5" />
        <rect x="300" y="450" width="160" height="50" rx="6" fill="rgba(6, 78, 59, 0.4)" stroke="#34d399" stroke-width="1.5" />
        <text x="380" y="470" fill="white" font-size="11" font-weight="600" text-anchor="middle">AWS Lambda</text>
        <text x="380" y="486" fill="#94a3b8" font-size="9" text-anchor="middle">Metadata / Validation</text>

        <!-- VPC Endpoint — S3 (AWS/Cloud) -->
        <rect x="540" y="220" width="150" height="50" rx="6" fill="#0f172a" stroke="#fbbf24" stroke-width="1.5" />
        <rect x="540" y="220" width="150" height="50" rx="6" fill="rgba(120, 53, 15, 0.3)" stroke="#fbbf24" stroke-width="1.5" />
        <text x="615" y="240" fill="white" font-size="10" font-weight="600" text-anchor="middle">VPC Endpoint</text>
        <text x="615" y="256" fill="#94a3b8" font-size="9" text-anchor="middle">Amazon S3</text>

        <!-- VPC Endpoint — Athena (AWS/Cloud) -->
        <rect x="540" y="290" width="150" height="50" rx="6" fill="#0f172a" stroke="#fbbf24" stroke-width="1.5" />
        <rect x="540" y="290" width="150" height="50" rx="6" fill="rgba(120, 53, 15, 0.3)" stroke="#fbbf24" stroke-width="1.5" />
        <text x="615" y="310" fill="white" font-size="10" font-weight="600" text-anchor="middle">VPC Endpoint</text>
        <text x="615" y="326" fill="#94a3b8" font-size="9" text-anchor="middle">Amazon Athena</text>

        <!-- VPC Endpoint — Glue (AWS/Cloud) -->
        <rect x="540" y="360" width="150" height="50" rx="6" fill="#0f172a" stroke="#fbbf24" stroke-width="1.5" />
        <rect x="540" y="360" width="150" height="50" rx="6" fill="rgba(120, 53, 15, 0.3)" stroke="#fbbf24" stroke-width="1.5" />
        <text x="615" y="380" fill="white" font-size="10" font-weight="600" text-anchor="middle">VPC Endpoint</text>
        <text x="615" y="396" fill="#94a3b8" font-size="9" text-anchor="middle">AWS Glue</text>

        <!-- S3 Data Lake (Database/Storage) -->
        <rect x="540" y="440" width="150" height="100" rx="6" fill="#0f172a" stroke="#a78bfa" stroke-width="1.5" />
        <rect x="540" y="440" width="150" height="100" rx="6" fill="rgba(76, 29, 149, 0.4)" stroke="#a78bfa" stroke-width="1.5" />
        <text x="615" y="462" fill="white" font-size="11" font-weight="600" text-anchor="middle">Amazon S3</text>
        <text x="615" y="480" fill="#94a3b8" font-size="9" text-anchor="middle">Data Lake</text>
        <text x="615" y="496" fill="#94a3b8" font-size="8" text-anchor="middle">• raw/ (partitioned)</text>
        <text x="615" y="510" fill="#94a3b8" font-size="8" text-anchor="middle">• curated/</text>
        <text x="615" y="528" fill="#a78bfa" font-size="7" text-anchor="middle">SSE-KMS encrypted</text>

        <!-- Glue Data Catalog (Database/Storage) -->
        <rect x="540" y="570" width="150" height="50" rx="6" fill="#0f172a" stroke="#a78bfa" stroke-width="1.5" />
        <rect x="540" y="570" width="150" height="50" rx="6" fill="rgba(76, 29, 149, 0.4)" stroke="#a78bfa" stroke-width="1.5" />
        <text x="615" y="590" fill="white" font-size="10" font-weight="600" text-anchor="middle">AWS Glue</text>
        <text x="615" y="606" fill="#94a3b8" font-size="9" text-anchor="middle">Data Catalog</text>

        <!-- KMS (Security) -->
        <rect x="540" y="650" width="150" height="50" rx="6" fill="#0f172a" stroke="#fb7185" stroke-width="1.5" />
        <rect x="540" y="650" width="150" height="50" rx="6" fill="rgba(136, 19, 55, 0.4)" stroke="#fb7185" stroke-width="1.5" />
        <text x="615" y="670" fill="white" font-size="11" font-weight="600" text-anchor="middle">AWS KMS</text>
        <text x="615" y="686" fill="#94a3b8" font-size="9" text-anchor="middle">Encryption at Rest</text>

        <!-- Athena (Database/Analytics) -->
        <rect x="900" y="270" width="150" height="55" rx="6" fill="#0f172a" stroke="#a78bfa" stroke-width="1.5" />
        <rect x="900" y="270" width="150" height="55" rx="6" fill="rgba(76, 29, 149, 0.4)" stroke="#a78bfa" stroke-width="1.5" />
        <text x="975" y="292" fill="white" font-size="11" font-weight="600" text-anchor="middle">Amazon Athena</text>
        <text x="975" y="308" fill="#94a3b8" font-size="9" text-anchor="middle">SQL Query Engine</text>

        <!-- Tableau Server (External/Third-party on AWS) -->
        <rect x="900" y="370" width="150" height="55" rx="6" fill="#0f172a" stroke="#22d3ee" stroke-width="1.5" />
        <rect x="900" y="370" width="150" height="55" rx="6" fill="rgba(8, 51, 68, 0.4)" stroke="#22d3ee" stroke-width="1.5" />
        <text x="975" y="390" fill="white" font-size="11" font-weight="600" text-anchor="middle">Tableau Server</text>
        <text x="975" y="406" fill="#94a3b8" font-size="9" text-anchor="middle">AWS EC2 / Auto Scaling</text>
        <text x="975" y="416" fill="#22d3ee" font-size="7" text-anchor="middle">Athena JDBC Driver</text>

        <!-- ========================================= -->
        <!-- LEGEND                                      -->
        <!-- ========================================= -->

        <text x="260" y="775" fill="white" font-size="10" font-weight="600">Legend</text>

        <rect x="260" y="785" width="16" height="10" rx="2" fill="rgba(30, 41, 59, 0.5)" stroke="#94a3b8" stroke-width="1" />
        <text x="282" y="793" fill="#94a3b8" font-size="8">External / Third-party</text>

        <rect x="400" y="785" width="16" height="10" rx="2" fill="rgba(120, 53, 15, 0.3)" stroke="#fbbf24" stroke-width="1" />
        <text x="422" y="793" fill="#94a3b8" font-size="8">AWS Managed Service</text>

        <rect x="560" y="785" width="16" height="10" rx="2" fill="rgba(6, 78, 59, 0.4)" stroke="#34d399" stroke-width="1" />
        <text x="582" y="793" fill="#94a3b8" font-size="8">Compute / Processing</text>

        <rect x="710" y="785" width="16" height="10" rx="2" fill="rgba(76, 29, 149, 0.4)" stroke="#a78bfa" stroke-width="1" />
        <text x="732" y="793" fill="#94a3b8" font-size="8">Storage / Analytics</text>

        <rect x="850" y="785" width="16" height="10" rx="2" fill="rgba(136, 19, 55, 0.4)" stroke="#fb7185" stroke-width="1" />
        <text x="872" y="793" fill="#94a3b8" font-size="8">Security</text>

        <line x1="940" y1="790" x2="956" y2="790" stroke="#fb7185" stroke-width="1" stroke-dasharray="4,3" />
        <text x="962" y="793" fill="#94a3b8" font-size="8">Private / Auth Flow</text>

        <line x1="260" y1="808" x2="276" y2="808" stroke="#64748b" stroke-width="1" marker-end="url(#arrowhead)" />
        <text x="282" y="811" fill="#94a3b8" font-size="8">Data Flow</text>
      </svg>
    </div>

    <!-- Footer -->
    <p class="footer">
      HDB Data Engineering Technical Test — Part 2: Architecture
    </p>
  </div>
</body>
</html>
